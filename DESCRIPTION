Package: copulaSFM
Type: Package
Title: Copula-Based Simultaneous Stochastic Frontier Models
Version: 0.1.0
Authors@R: c(
  person("Woraphon", "Yamaka",
         email = "woraphon.econ@gmail.com",
         role = c("aut", "cre")),
